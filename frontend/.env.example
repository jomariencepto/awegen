# Frontend Vite environment example
# Copy to "frontend/.env" for local development if you need overrides.

PORT=3000
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:5000
VITE_API_URL=/api
REACT_APP_API_URL=/api

# Optional HMR overrides for remote dev URLs / reverse proxies.
# Leave these unset for normal localhost dev; Vite auto-selects ws/wss.
#
# HTTP remote example:
# VITE_HMR_HOST=awegen.online
# VITE_HMR_PROTOCOL=ws
# VITE_HMR_CLIENT_PORT=80
#
# HTTPS remote example:
# VITE_HMR_HOST=awegen.online
# VITE_HMR_PROTOCOL=wss
# VITE_HMR_CLIENT_PORT=443
#
# Optional HMR path when your proxy forwards WebSockets on a custom route.
# VITE_HMR_PATH=/vite-hmr
#
# Disable HMR completely if your proxy cannot forward WebSockets.
# VITE_DISABLE_HMR=true

