# Backend Flask environment example
# Copy to "backend/.env" for local non-Docker development.

FLASK_APP=main.py
FLASK_ENV=development
FLASK_DEBUG=1

SECRET_KEY=change-me-secret-key
JWT_SECRET_KEY=change-me-jwt-secret-key
DATABASE_URL=mysql+pymysql://root@localhost/awegen_db

UPLOAD_FOLDER=uploads
NLP_MODEL_PATH=models/nlp
REDIS_URL=redis://localhost:6379/0

AI_SPACY_MODEL=en_core_web_md
AI_SPACY_FALLBACK_MODEL=en_core_web_sm
AI_SPACY_MAX_CHUNK_CHARS=200000
AI_SPACY_BATCH_SIZE=32
AI_SPACY_N_PROCESS=1
AI_T5_MODEL=t5-small
AI_IDF_CACHE_DIR=temp/idf_cache

SMTP_SERVER=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=
FROM_NAME=AWEGen System
APP_LOGIN_URL=http://localhost:3000/auth/login

JWT_DISABLE_EXPIRATION=false
PDF_DOWNLOAD_PASSWORD=

